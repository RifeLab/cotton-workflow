<resources>
    <!-- Base application theme. -->
    <style name="Theme.Cotton" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="windowNoTitle">true</item>
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/light</item>
        <item name="colorPrimaryVariant">@color/accent</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/dark</item>
        <item name="colorSecondaryVariant">@color/accent2</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/dark</item>

        <item name="buttonBarPositiveButtonStyle">@style/PositiveButtonStyle</item>
        <item name="buttonBarNegativeButtonStyle">@style/NegativeButtonStyle</item>
    </style>

    <style name="Theme.Cotton.Button.Save">
        <item name="android:backgroundTint">@color/accent</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="AlertDialogTheme" parent="ThemeOverlay.AppCompat.Dialog.Alert">
        <item name="android:buttonBarNegativeButtonStyle">@style/NegativeButtonStyle</item>
        <item name="android:buttonBarPositiveButtonStyle">@style/PositiveButtonStyle</item>
    </style>

    <style name="NegativeButtonStyle" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/accent</item>
    </style>

    <style name="PositiveButtonStyle" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/accent</item>
    </style>

    <style name="Theme.Cotton.Text" parent="TextAppearance.AppCompat.Body1">
        <item name="android:textSize">20sp</item>
        <item name="android:layout_margin">8dp</item>
    </style>

    <style name="Theme.Cotton.SubSample.Text" parent="@style/Theme.Cotton.Text">
        <item name="android:textSize">15sp</item>
        <item name="android:layout_margin">8dp</item>
    </style>

    <style name="Theme.Cotton.TitleText" parent="TextAppearance.AppCompat.Headline">
        <item name="android:textSize">30sp</item>
        <item name="android:layout_margin">8dp</item>
    </style>

    <style name="Theme.Cotton.Dialog.Title" parent="TextAppearance.AppCompat.Title"/>
    <style name="Theme.Cotton.Dialog.Subtitle" parent="TextAppearance.AppCompat.Subhead"/>

    <style name="Theme.Cotton.WeightEditText" parent="TextAppearance.AppCompat.Headline">
        <item name="android:textSize">30sp</item>
        <item name="android:layout_margin">8dp</item>
        <item name="android:gravity">center_horizontal</item>
    </style>

    <style name="Theme.Cotton.Button" parent="TextAppearance.MaterialComponents.Button">
        <item name="android:layout_margin">8dp</item>
    </style>

    <style name="Theme.Cotton.Toolbar" parent="Widget.AppCompat.Toolbar">
        <item name="android:background">@color/light</item>
    </style>

</resources>