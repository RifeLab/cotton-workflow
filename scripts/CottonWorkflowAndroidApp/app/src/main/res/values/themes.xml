<resources>
    <!-- Base application theme. -->
    <style name="Theme.Cotton" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="windowNoTitle">true</item>
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/pistachio</item>
        <item name="colorPrimaryVariant">@color/olivine</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/dim_gray</item>
        <item name="colorSecondaryVariant">@color/walnut_brown</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
    </style>

    <style name="Theme.Cotton.Text" parent="TextAppearance.AppCompat.Body1">
        <item name="android:textSize">20sp</item>
        <item name="android:layout_margin">8dp</item>
    </style>

    <style name="Theme.Cotton.TitleText" parent="TextAppearance.AppCompat.Headline">
        <item name="android:textSize">30sp</item>
        <item name="android:layout_margin">8dp</item>
    </style>

    <style name="Theme.Cotton.WeightEditText" parent="TextAppearance.AppCompat.Headline">
        <item name="android:textSize">30sp</item>
        <item name="android:layout_margin">8dp</item>
        <item name="android:gravity">center_horizontal</item>
    </style>

    <style name="Theme.Cotton.Button" parent="TextAppearance.MaterialComponents.Button">
        <item name="android:layout_margin">8dp</item>
    </style>

    <style name="Theme.Cotton.Toolbar" parent="Widget.AppCompat.Toolbar">
        <item name="android:background">?colorAccent</item>
    </style>

</resources>