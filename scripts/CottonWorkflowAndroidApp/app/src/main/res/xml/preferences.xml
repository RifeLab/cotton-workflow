<?xml version="1.0" encoding="utf-8"?>

<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:key="@string/key_pref_screen">

    <PreferenceCategory
        android:key="transfer_defaults"
        android:title="@string/preferences_profile"
        app:iconSpaceReserved="false">

        <EditTextPreference android:title="@string/pref_person_title"
            android:icon="@drawable/ic_pref_profile_person"
            android:key="@string/key_preferences_person"
            android:summary="@string/pref_person_summary"/>

        <CheckBoxPreference
            android:defaultValue="false"
            android:icon="@drawable/ic_pref_profile_verify"
            android:key="@string/key_preferences_person_require"
            android:title="@string/pref_person_require_title"
            android:summary="@string/pref_person_require_summary"/>

        <ListPreference
            android:entries="@array/preferences_profile_ask_user_interval_entries"
            android:entryValues="@array/preferences_profile_ask_user_interval_values"
            android:icon="@drawable/hours_24"
            android:key="@string/key_preferences_person_require_interval"
            android:title="@string/pref_profile_person_require_title"
            android:summary="@string/pref_profile_person_require_summary"/>

    </PreferenceCategory>

    <PreferenceCategory
        android:title="@string/preferences_workflow"
        app:iconSpaceReserved="false">

        <EditTextPreference android:title="@string/preferences_start_id_chooser"
            android:summary=""
            android:icon="@drawable/identifier"
            android:key="@string/key_preferences_workflow_id_start"/>

    </PreferenceCategory>

    <PreferenceCategory
        android:title="@string/preferences_devices"
        app:iconSpaceReserved="false">

        <Preference android:title="@string/preferences_scale_device_chooser"
            android:summary=""
            android:icon="@drawable/scale"
            android:key="@string/key_preferences_scale_device_id"/>

        <Preference android:title="@string/preferences_printer_device_chooser"
            android:summary=""
            android:icon="@drawable/printer_outline"
            android:key="@string/key_preferences_printer_device_id"/>

        <Preference android:title="@string/preferences_device_id_clear_title"
            android:icon="@android:drawable/ic_delete"
            android:key="@string/key_preferences_device_id_clear"/>

    </PreferenceCategory>

</PreferenceScreen>