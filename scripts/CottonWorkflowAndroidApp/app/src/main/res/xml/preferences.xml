    <PreferenceCategory
        android:title="@string/preferences_devices"
        app:iconSpaceReserved="false">

        <Preference android:title="@string/preferences_scale_device_chooser"
            android:summary=""
            android:icon="@drawable/scale"
            android:key="@string/key_preferences_scale_device_id"/>

        <Preference android:title="@string/preferences_printer_device_chooser"
            android:summary=""
            android:icon="@drawable/printer_outline"
            android:key="@string/key_preferences_printer_device_id"/>

        <Preference android:title="@string/preferences_device_id_clear_title"
