<?xml version="1.0" encoding="utf-8"?>

<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/navigation_root"
    app:startDestination="@+id/fragment_sample_list">

    <fragment android:id="@+id/fragment_sample_list"
        android:name="org.phenoapps.cotton.fragments.SampleListFragment"
        android:label="Sample List Fragment"
        tools:layout="@layout/fragment_sample_list"/>

    <fragment android:id="@+id/fragment_preferences"
        android:name="org.phenoapps.cotton.fragments.PreferencesFragment"
        android:label="Preferences">
        <action android:id="@+id/action_to_scale_config_help"
            app:destination="@id/fragment_scale_config_help"
            app:popUpTo="@id/fragment_preferences"
            app:launchSingleTop="true"/>
    </fragment>

    <fragment android:id="@+id/fragment_device_chooser"
        android:name="org.phenoapps.cotton.fragments.BluetoothDeviceChooserFragment"
        android:label="Device Chooser"/>

    <fragment android:id="@+id/fragment_workflow"
        android:name="org.phenoapps.cotton.fragments.SampleWorkflowFragment"
        android:label="Workflow"/>

    <fragment android:id="@+id/fragment_sample"
        android:name="org.phenoapps.cotton.fragments.SampleEditFragment"
        android:label="Sample">
        <action android:id="@+id/action_to_workflow_fragment"
            app:destination="@id/fragment_workflow"
            app:popUpTo="@id/fragment_sample_list"
            app:launchSingleTop="true">
            <argument android:name="sample"
                app:argType="org.phenoapps.cotton.models.SampleModel"
                app:nullable="true"/>
        </action>
    </fragment>

    <fragment android:id="@+id/fragment_scale_config_help"
        android:name="org.phenoapps.cotton.fragments.ScaleConfigHelpFragment"
        android:label="Scale Config Helper"/>

    <action android:id="@+id/global_action_to_sample"
        app:destination="@id/fragment_sample"
        app:launchSingleTop="true">
        <argument android:name="sample"
            app:argType="org.phenoapps.cotton.models.SampleModel"
            app:nullable="true"/>
        <argument android:name="new"
            android:defaultValue="false"
            app:argType="boolean"/>
    </action>

    <action android:id="@+id/global_action_to_workflow_fragment"
        app:destination="@id/fragment_workflow"
        app:launchSingleTop="true">
        <argument android:name="sample"
            app:argType="org.phenoapps.cotton.models.SampleModel"
            app:nullable="true"/>
        <argument android:name="new"
            android:defaultValue="false"
            app:argType="boolean"/>
    </action>

    <action android:id="@+id/global_action_to_device_chooser_fragment"
        app:destination="@+id/fragment_device_chooser"
        app:launchSingleTop="true">
        <argument android:name="deviceType"
            app:argType="string"
            app:nullable="false"/>
    </action>

    <action android:id="@+id/global_action_to_preferences_fragment"
        app:destination="@id/fragment_preferences"
        app:launchSingleTop="true"
        app:popUpTo="@id/fragment_preferences">
        <argument android:name="action"
            android:defaultValue=""
            app:nullable="true"
            app:argType="string"/>
    </action>

    <action android:id="@+id/global_action_to_home_fragment"
        app:destination="@id/fragment_sample_list"
        app:launchSingleTop="true"
        app:popUpTo="@id/fragment_sample_list"/>

</navigation>