<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/list_item_sample_content"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    android:background="@drawable/cell">

    <ImageView
        android:id="@+id/list_item_sample_code_iv"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_icon_launcher"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_margin="8dp"
        android:contentDescription="TODO" />

    <ImageView
        android:tag="down"
        android:padding="8dp"
        android:id="@+id/list_item_sample_expand_iv"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/chevron_down"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:contentDescription="TODO" />

    <ImageView android:id="@+id/list_item_sample_scan_header_iv"
        android:padding="4dp"
        android:layout_margin="8dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/barcode_scan"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/list_item_sample_code_header_tv"
        android:contentDescription="TODO" />

    <ImageView android:id="@+id/list_item_sample_id_header_iv"
        android:padding="4dp"
        android:layout_margin="8dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/identifier"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/list_item_sample_code_iv"
        android:contentDescription="TODO" />

    <TextView style="@style/Theme.Cotton.Text"
        android:layout_margin="8dp"
        android:id="@+id/list_item_sample_code_header_tv"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/list_item_sample_code_iv"
        app:layout_constraintStart_toEndOf="@id/list_item_sample_scan_header_iv"
        app:layout_constraintEnd_toEndOf="parent"
        android:singleLine="true"
        android:ellipsize="marquee"
        tools:text="Sample Barcode ID *99010899"/>

    <TextView style="@style/Theme.Cotton.Text"
        android:layout_margin="8dp"
        android:id="@+id/list_item_sample_timestamp_header_tv"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/list_item_sample_code_header_tv"
        app:layout_constraintStart_toEndOf="@id/list_item_sample_scan_header_iv"
        app:layout_constraintEnd_toEndOf="parent"
        android:singleLine="true"
        android:ellipsize="marquee"
        tools:text="Jan 1 2121"/>

    <ImageView android:id="@+id/list_item_sample_scale_header_iv"
        android:padding="4dp"
        android:layout_margin="8dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/scale"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/list_item_sample_timestamp_header_tv"
        android:contentDescription="TODO" />

    <TextView style="@style/Theme.Cotton.Text"
        android:layout_margin="8dp"
        android:id="@+id/list_item_sample_weight_timestamp_header_tv"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/list_item_sample_timestamp_header_tv"
        app:layout_constraintStart_toEndOf="@id/list_item_sample_scale_header_iv"
        app:layout_constraintEnd_toEndOf="parent"
        android:singleLine="true"
        android:ellipsize="marquee"
        tools:text="Jan 1 2121"/>

    <ImageView android:id="@+id/list_item_sample_weight_header_iv"
        android:padding="4dp"
        android:layout_margin="8dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/weight"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/list_item_sample_weight_timestamp_header_tv"
        android:contentDescription="TODO" />

    <TextView style="@style/Theme.Cotton.Text"
        android:layout_margin="8dp"
        android:id="@+id/list_item_sample_weight_header_tv"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/list_item_sample_weight_timestamp_header_tv"
        app:layout_constraintStart_toEndOf="@id/list_item_sample_weight_header_iv"
        app:layout_constraintEnd_toEndOf="parent"
        android:singleLine="true"
        android:ellipsize="marquee"
        tools:text="1g"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/list_item_sample_sub_sample_rv"
        android:layout_margin="8dp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        android:orientation="vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/list_item_sample_weight_header_tv"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:listitem="@layout/list_item_sample"/>
    <!--        tools:itemCount="2"-->

    <TextView style="@style/Theme.Cotton.Text"
        android:id="@+id/list_item_sample_analysis_tv"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/list_item_sample_sub_sample_rv"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:singleLine="true"
        android:ellipsize="marquee"
        android:gravity="center_horizontal"
        tools:text="0.01% error"/>

</androidx.constraintlayout.widget.ConstraintLayout>