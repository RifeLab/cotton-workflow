<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <ScrollView
        android:id="@+id/frag_workflow_sv"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/frag_sample_save_btn">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <TextView style="@style/Theme.Cotton.Text"
                android:layout_margin="8dp"
                android:id="@+id/frag_sample_code_tv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:ignore="MissingConstraints"
                tools:text="*992020001801"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:background="@drawable/sample_cell"
                android:id="@+id/frag_sample_title_bar"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/frag_sample_code_tv"
                app:layout_constraintBottom_toTopOf="@id/frag_sample_total_weight_header_tv"/>

            <ImageView android:id="@+id/frag_workflow_numeric_one_iv"
                android:padding="4dp"
                android:layout_margin="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/numeric_1_circle_outline"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/frag_sample_title_bar"
                android:contentDescription="TODO" />

            <TextView style="@style/Theme.Cotton.Text"
                android:layout_margin="8dp"
                android:id="@+id/frag_sample_total_weight_header_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/frag_sample_total_weight"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/frag_workflow_numeric_one_iv"
                app:layout_constraintTop_toBottomOf="@+id/frag_sample_title_bar"
                tools:ignore="MissingConstraints" />

            <EditText style="@style/Theme.Cotton.Text"
                android:layout_margin="8dp"
                android:id="@+id/frag_sample_total_weight_et"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="@string/frag_sample_total_weight_hint"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/frag_sample_total_weight_header_tv"
                tools:ignore="MissingConstraints"
                android:autofillHints=""
                android:imeOptions="actionNext"
                android:selectAllOnFocus="true"
                android:inputType="numberDecimal" />

            <TextView
                android:id="@+id/frag_sample_total_weight_time_tv"
                style="@style/Theme.Cotton.Text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:gravity="end"
                android:lines="1"
                android:textStyle="bold"
                app:layout_constraintBottom_toTopOf="@+id/frag_sample_total_weight_et"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="1"
                app:layout_constraintStart_toEndOf="@+id/frag_sample_total_weight_header_tv"
                app:layout_constraintTop_toBottomOf="@+id/frag_sample_title_bar"
                tools:ignore="MissingConstraints"
                tools:text="1 Jan 1990" />

            <ImageView android:id="@+id/frag_workflow_numeric_two_iv"
                android:padding="4dp"
                android:layout_margin="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/numeric_2_circle_outline"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/frag_sample_total_weight_et"
                android:contentDescription="TODO" />

            <TextView style="@style/Theme.Cotton.Text"
                android:layout_margin="8dp"
                android:id="@+id/frag_sample_seed_weight_header_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/frag_sample_seed_weight"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/frag_workflow_numeric_two_iv"
                app:layout_constraintTop_toBottomOf="@+id/frag_sample_total_weight_et"
                tools:ignore="MissingConstraints" />

            <EditText style="@style/Theme.Cotton.Text"
                android:layout_margin="8dp"
                android:id="@+id/frag_sample_seed_weight_et"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="@string/frag_sample_total_weight_hint"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/frag_sample_seed_weight_header_tv"
                tools:ignore="MissingConstraints"
                android:autofillHints=""
                android:imeOptions="actionNext"
                android:selectAllOnFocus="true"
                android:inputType="numberDecimal" />

            <TextView
                android:id="@+id/frag_sample_seed_weight_time_tv"
                style="@style/Theme.Cotton.Text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:gravity="end"
                android:lines="1"
                android:textStyle="bold"
                app:layout_constraintBottom_toTopOf="@+id/frag_sample_seed_weight_et"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="1"
                app:layout_constraintStart_toEndOf="@id/frag_sample_seed_weight_header_tv"
                app:layout_constraintTop_toBottomOf="@+id/frag_sample_total_weight_et"
                tools:ignore="MissingConstraints"
                tools:text="1 Jan 1990" />

            <ImageView android:id="@+id/frag_workflow_numeric_three_iv"
                android:padding="4dp"
                android:layout_margin="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/numeric_3_circle_outline"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/frag_sample_seed_weight_et"
                android:contentDescription="TODO" />

            <TextView style="@style/Theme.Cotton.Text"
                android:layout_margin="8dp"
                android:id="@+id/frag_sample_lint_weight_header_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/frag_sample_lint_weight"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/frag_workflow_numeric_three_iv"
                app:layout_constraintTop_toBottomOf="@+id/frag_sample_seed_weight_et"
                tools:ignore="MissingConstraints" />

            <EditText style="@style/Theme.Cotton.Text"
                android:layout_margin="8dp"
                android:id="@+id/frag_sample_lint_weight_et"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="@string/frag_sample_total_weight_hint"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/frag_sample_lint_weight_header_tv"
                tools:ignore="MissingConstraints"
                android:autofillHints=""
                android:imeOptions="actionNext"
                android:selectAllOnFocus="true"
                android:inputType="numberDecimal" />

            <TextView
                android:id="@+id/frag_sample_lint_weight_time_tv"
                style="@style/Theme.Cotton.Text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:gravity="end"
                android:lines="1"
                android:textStyle="bold"
                app:layout_constraintBottom_toTopOf="@id/frag_sample_lint_weight_et"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="1"
                app:layout_constraintStart_toEndOf="@id/frag_sample_lint_weight_header_tv"
                app:layout_constraintTop_toBottomOf="@+id/frag_sample_seed_weight_et"
                tools:ignore="MissingConstraints"
                tools:text="1 Jan 1990" />

            <ImageView android:id="@+id/frag_workflow_numeric_four_iv"
                android:padding="4dp"
                android:layout_margin="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/numeric_4_circle_outline"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/frag_sample_lint_weight_et"
                android:contentDescription="TODO" />

            <TextView style="@style/Theme.Cotton.Text"
                android:layout_margin="8dp"
                android:id="@+id/frag_sample_test_weight_header_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/frag_sample_test_weight"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/frag_workflow_numeric_four_iv"
                app:layout_constraintTop_toBottomOf="@+id/frag_sample_lint_weight_et"
                tools:ignore="MissingConstraints" />

            <EditText style="@style/Theme.Cotton.Text"
                android:layout_margin="8dp"
                android:id="@+id/frag_sample_test_weight_et"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="@string/frag_sample_total_weight_hint"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/frag_sample_test_weight_header_tv"
                tools:ignore="MissingConstraints"
                android:imeOptions="actionNext"
                android:autofillHints=""
                android:selectAllOnFocus="true"
                android:inputType="numberDecimal" />

            <TextView
                android:id="@+id/frag_sample_test_weight_time_tv"
                style="@style/Theme.Cotton.Text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:gravity="end"
                android:lines="1"
                android:textStyle="bold"
                app:layout_constraintBottom_toTopOf="@id/frag_sample_test_weight_et"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="1"
                app:layout_constraintStart_toEndOf="@id/frag_sample_test_weight_header_tv"
                app:layout_constraintTop_toBottomOf="@+id/frag_sample_lint_weight_et"
                tools:ignore="MissingConstraints"
                tools:text="1 Jan 1990" />

            <ImageView android:id="@+id/frag_workflow_numeric_five_iv"
                android:padding="4dp"
                android:layout_margin="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/numeric_5_circle_outline"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/frag_sample_test_weight_et"
                android:contentDescription="TODO" />

            <TextView style="@style/Theme.Cotton.Text"
                android:layout_margin="8dp"
                android:id="@+id/frag_sample_test_code_header_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/frag_sample_test_barcode_header"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/frag_workflow_numeric_four_iv"
                app:layout_constraintTop_toBottomOf="@+id/frag_sample_test_weight_et"
                tools:ignore="MissingConstraints" />

            <EditText style="@style/Theme.Cotton.Text"
                android:layout_margin="8dp"
                android:id="@+id/frag_sample_test_barcode_et"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="@string/frag_sample_barcode_hint"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/frag_sample_test_code_header_tv"
                tools:ignore="MissingConstraints"
                android:autofillHints=""
                android:selectAllOnFocus="true"
                android:inputType="numberDecimal" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>

    <Button style="@style/Theme.Cotton.Button.Save"
        android:layout_margin="8dp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:id="@+id/frag_sample_save_btn"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/frag_workflow_sv"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:text="@string/frag_sample_save_btn"/>

</androidx.constraintlayout.widget.ConstraintLayout>

